# =============================================================================
# Zoids League — Variables de entorno (backend Django)
# =============================================================================
# Copia este archivo a `.env` y completa los valores. `.env` está en .gitignore
# y NUNCA debe versionarse. En producción, define estas variables en el entorno
# del contenedor / orquestador.
# -----------------------------------------------------------------------------

# --- Base de datos PostgreSQL ---
DB_NAME=league_db
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=db
DB_PORT=5432

# --- Seguridad Django ---
# OBLIGATORIO en producción: genera una clave única y secreta.
# Generar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion

# Mantener en False en producción.
DJANGO_DEBUG=False

# Lista de hosts permitidos separada por comas. En producción restringe a los
# dominios reales, p. ej.: midominio.com,www.midominio.com
# El valor '*' solo es aceptable en desarrollo local.
DJANGO_ALLOWED_HOSTS=*

# Nivel de logging: DEBUG | INFO | WARNING | ERROR (WARNING recomendado en prod).
LOG_LEVEL=WARNING

# --- Integración de IA (OpenRouter) ---
OPENROUTER_API_KEY=tu-api-key-de-openrouter
