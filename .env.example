# ----------------------------------------------------------------------------
# Production environment for Zoids League.
# Copy this file to ".env" on the VPS and fill in REAL values.
# Never commit the real .env (it is already git-ignored).
# ----------------------------------------------------------------------------

# --- Django core ---
# Generate a fresh key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_generate_a_new_secret_key

DEBUG=False

# Your domain(s), comma-separated (no protocol).
ALLOWED_HOSTS=example.com,www.example.com

# Origins trusted for CSRF / Django admin over HTTPS (WITH protocol).
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# --- Database (PostgreSQL) ---
DB_NAME=league_db
DB_USER=league_admin
# Use a long random password, NOT "admin".
DB_PASSWORD=CHANGE_ME_strong_db_password

# --- External services ---
OPENROUTER_API_KEY=your_openrouter_api_key

# --- TLS / Nginx ---
# Domain used by Nginx and Certbot (single domain, no protocol).
DOMAIN=example.com
# Email Let's Encrypt uses for expiry notices.
CERTBOT_EMAIL=you@example.com
